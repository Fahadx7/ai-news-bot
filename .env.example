# ─────────────────────────────────────────────
# AI News Bot — Environment Variables
# ─────────────────────────────────────────────

# Groq API (مطلوب)
# https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (اختياري) النموذج المفضل — افتراضي: llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile

# Telegram Bot (مطلوب)
# 1. أنشئ بوت من @BotFather واحصل على token
# 2. ابعث /start لبوتك
# 3. روح: https://api.telegram.org/bot<TOKEN>/getUpdates
#    → خذ chat.id من الرد
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890
